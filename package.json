{
  "name": "exchangethb",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "worker": "tsx worker/index.ts",
    "worker:daemon": "WORKER_LOOP=1 tsx worker/index.ts",
    "health:prod": "bash ./scripts/check-prod-health.sh",
    "seo:cluster": "node ./scripts/check-seo-cluster.mjs",
    "gsc:authorize": "node ./scripts/gsc.mjs authorize",
    "gsc:sites": "node ./scripts/gsc.mjs sites",
    "gsc:analytics": "node ./scripts/gsc.mjs search-analytics",
    "gsc:sitemaps": "node ./scripts/gsc.mjs sitemaps",
    "gsc:inspect": "node ./scripts/gsc.mjs inspect-url",
    "test:smoke:market": "tsx scripts/smoke-market.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "clsx": "^2.1.1",
    "next": "^15.5.12",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "prisma": "^6.5.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^2.1.8"
  }
}
